-    if target_host == host or target_host:match(host) then
-      matching_callback = callback
-      break
+  local function find_callback(hostname)
+    for host, callback in pairs(M.callbacks) do
+      if hostname == host or hostname:match(host) then
+        return callback
+      end
     end
   end
+
+  local matching_callback = find_callback(target_host)
   if not matching_callback then
+    local resolved_host = resolve_ssh_host(target_host)
+    if resolved_host and resolved_host ~= target_host then
+      local resolved_callback = find_callback(resolved_host)
+      if resolved_callback then
+        return function(url_data)
+          url_data.host = resolved_host
+          return resolved_callback(url_data)
+        end
+      end
+    end
+
     vim.notify(
       string.format("No host callback defined for host '%s'", target_host),
       vim.log.levels.ERROR
     )
+    return nil
   end
+
   return matching_callback
 end
 
