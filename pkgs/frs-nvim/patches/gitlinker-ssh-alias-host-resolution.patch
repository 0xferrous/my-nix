--- a/lua/gitlinker/hosts.lua
+++ b/lua/gitlinker/hosts.lua
@@ -163,6 +163,31 @@
   return url
 end
 
+local resolved_host_cache = {}
+
+local function resolve_ssh_host(alias)
+  if resolved_host_cache[alias] ~= nil then
+    return resolved_host_cache[alias]
+  end
+
+  local output = vim.fn.systemlist({ "ssh", "-G", alias })
+  if vim.v.shell_error ~= 0 then
+    resolved_host_cache[alias] = false
+    return nil
+  end
+
+  for _, line in ipairs(output) do
+    local key, value = line:match("^(%S+)%s+(.+)$")
+    if key == "hostname" and value and value ~= "" then
+      resolved_host_cache[alias] = value
+      return value
+    end
+  end
+
+  resolved_host_cache[alias] = false
+  return nil
+end
+
 --- Gets a matching callback for a given host
 --
 -- @param target_host the host to get the matching callback from.
@@ -170,19 +195,34 @@
